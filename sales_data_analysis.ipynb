    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "data = {\n",
    "    \"Month\": [\"Jan\", \"Feb\", \"Mar\", \"Apr\"],\n",
    "    \"Sales\": [200, 300, 250, 400]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "df.plot(x=\"Month\", y=\"Sales\", kind=\"line\", title=\"Monthly Sales\")\n",
    "plt.show()"
   ]
